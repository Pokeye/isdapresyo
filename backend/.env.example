# Server
PORT=3000
NODE_ENV=development

# Postgres (recommended: use DATABASE_URL)
DATABASE_URL=postgres://postgres:password@localhost:5432/isdapresyo

# Managed Postgres providers (Supabase/Render/etc.) often require SSL.
# - Set to true to force SSL even in development.
# - You can also set DATABASE_SSL=true.
PGSSL=false

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# Security / Deployment
FRONTEND_ORIGIN=http://localhost:3000
ENFORCE_HTTPS=false
ADMIN_PATH=/admin
SERVE_FRONTEND=true
